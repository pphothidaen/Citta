# Environment variables for Citta — Proxy Gateway
# Copy this file to .env and fill in your real API keys.
# NEVER commit .env — it is gitignored.

# ── DeepSeek ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"
DEEPSEEK_API_BASE="https://api.deepseek.com/v1"

# ── Google / Gemini ───────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key-here"
GOOGLE_API_KEY="your-google-api-key-here"

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-your-openai-api-key-here"

# ── Shared Citta services ─────────────────────────────────────────────────────
REDIS_AUTH="change-me"
OLLAMA_BASE_URL="http://ollama:11434"

# Use real IPs or DNS names when nodes run on separate machines.
NODE1_URL="http://node1.local:8000"
QDRANT_URL="http://node2.local:6333"
NODE2_REDIS_URL="redis://:change-me@node2.local:6379/0"
NODE3_INGEST_URL="http://node3.local:8001/v1/ingest"
INGEST_QUEUE="citta:ingest"
EDGE_SOURCE_URL="https://example.com"
POLL_INTERVAL_SECONDS="60"
