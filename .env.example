# Citta — environment variables template
# Copy to .env and fill in values before running.
# Phase 1: all services on localhost (Node 1).
# Phase 2: update *_HOST to Node 2 IP (e.g. 192.168.1.20).

# --- MinIO (S3 Storage) ---
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=cittaadmin
MINIO_ROOT_PASSWORD=cittasecret
MINIO_BUCKET=citta-lake
MINIO_SECURE=false

# --- ChromaDB (Vector Store) ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=citta-memory

# --- LLM (Ollama local, Node 1) ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
