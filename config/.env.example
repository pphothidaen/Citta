# ─────────────────────────────────────────────────────────────
# Citta – Environment Configuration
# Copy this file to config/.env and fill in your values.
# NEVER commit config/.env (it is listed in .gitignore).
#
# Virtual Hostnames Strategy:
#   All service addresses are defined here so that moving from
#   Phase 1 (local Docker) → Phase 2 (Synology DS224+ over LAN)
#   requires only editing this file – no Business Logic changes.
# ─────────────────────────────────────────────────────────────

# ── Node Identifiers ────────────────────────────────────────
# Node 1: Mac M4 (Orchestrator / Local LLM host)
NODE1_HOST=node1.citta.local

# Node 2: Intermediate ingestion point (receives data from Node 4)
NODE2_HOST=node2.citta.local
NODE2_PORT=8080

# Node 3: J1900 edge server running n8n for Action dispatch
NODE3_HOST=node3.citta.local
NODE3_N8N_PORT=5678
NODE3_N8N_WEBHOOK_PATH=/webhook/citta-action

# Node 4: Huawei Y9 (Android ARM scraper)
NODE4_HOST=node4.citta.local
NODE4_API_PORT=8081

# ── MinIO (Object Storage) ────────────────────────────────────
# Phase 1: points at local Docker container (hostname = minio)
# Phase 2: change MINIO_HOST to synology.citta.local
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=citta_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MINIO_DEFAULT_BUCKET=citta-raw

# ── ChromaDB (Vector Database) ────────────────────────────────
# Phase 1: points at local Docker container (hostname = chromadb)
# Phase 2: change CHROMA_HOST to synology.citta.local
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_AUTH_TOKEN=CHANGE_ME_CHROMA_TOKEN
CHROMA_AUTH_PROVIDER=chromadb.auth.token.TokenAuthServerProvider
CHROMA_COLLECTION=citta_perception

# ── Local LLM (Ollama on Mac M4) ─────────────────────────────
# Ollama runs natively on macOS; containers call the host's port
LOCAL_LLM_HOST=host.docker.internal
LOCAL_LLM_PORT=11434
LOCAL_LLM_MODEL=llama3

# ── Orchestrator ──────────────────────────────────────────────
ORCHESTRATOR_POLL_INTERVAL_SECONDS=30
ORCHESTRATOR_LOG_LEVEL=INFO
